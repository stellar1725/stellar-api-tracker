{
  "manifest_version": 3,
  "name": "Stellar — API Tracker",
  "version": "2.0.0",
  "description": "Captures every XHR/Fetch API call across browser tabs. Built for pentesters and developers to map API coverage during web app crawling.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webRequest",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
