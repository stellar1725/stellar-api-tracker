{
  "manifest_version": 2,
  "name": "Stellar — API Tracker",
  "version": "2.0.0",
  "description": "Captures every XHR/Fetch API call across browser tabs. Built for pentesters and developers to map API coverage during web app crawling.",
  "browser_specific_settings": {
    "gecko": {
      "id": "stellar-api-tracker@pentest",
      "strict_min_version": "91.0"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webRequest",
    "webRequestBlocking",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    "dashboard.html",
    "icons/*"
  ]
}
